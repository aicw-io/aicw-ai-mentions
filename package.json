{
  "name": "aicw-ai-mentions",
  "version": "1.2.1",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "description": "Open-source CLI for tracking how AI assistants mention your brand, products, and competitors",
  "type": "module",
  "bin": {
    "aicw-ai-mentions": "./bin/aicw-ai-mentions.js"
  },
  "files": [
    "bin/",
    "docs/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "postbuild": "node script/copy-assets.js",
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node bin/aicw-ai-mentions.js",
    "test": "npm run build && node --test tests/*.test.mjs",
    "test:local": "npm run build && node bin/aicw-ai-mentions.js help",
    "demo:build": "bash script/build-demo-pages.sh",
    "demo:pages": "npm run demo:build",
    "link:local": "npm run build && npm link && echo 'aicw-ai-mentions command is now available globally'",
    "unlink:local": "npm unlink -g aicw-ai-mentions && echo 'aicw-ai-mentions command removed'",
    "prepublishOnly": "npm run build && npm test && npm run package:dry",
    "clean": "rimraf dist/ .last-build *.tgz .tmp/",
    "rebuild": "npm run clean && npm run build",
    "prepack": "npm run build",
    "package:dry": "npm pack --dry-run",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version"
  },
  "keywords": [
    "ai",
    "rankings",
    "ai-mentions",
    "monitoring",
    "llm",
    "gpt",
    "claude",
    "gemini",
    "perplexity",
    "ai-tools",
    "cli",
    "openai",
    "agpl"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aicw-io/aicw-ai-mentions"
  },
  "homepage": "https://github.com/aicw-io/aicw-ai-mentions#readme",
  "bugs": {
    "url": "https://github.com/aicw-io/aicw-ai-mentions/issues"
  },
  "author": "Evgenii Mironichev",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "csv-parse": "^5.5.0",
    "dotenv": "^16.4.7",
    "fs-extra": "^11.2.0",
    "marked": "^16.0.0",
    "openai": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.24",
    "rimraf": "^5.0.10",
    "typescript": "^5.8.3"
  }
}